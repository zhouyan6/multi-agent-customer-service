{
    "dependencies": [
        "."
    ],
    "graphs": {
        "customer_service": "./multi_agent_customer_service.py:make_graph"
    },
    "env": "./.env",
    "python_version": "3.11",
    "base_image": "langchain/langgraph-api:0.2",
    "store": {
        "ttl": {
            "refresh_on_read": true,
            "sweep_interval_minutes": 60,
            "default_ttl": 10080
        }
    },
    "checkpointer": {
        "ttl": {
            "strategy": "delete",
            "sweep_interval_minutes": 10,
            "default_ttl": 43200
        }
    }
}
